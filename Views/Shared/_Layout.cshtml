<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Financeiro</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            /* --- AJUSTE PARA RODAPÉ FIXO NO CHÃO (STICKY FOOTER) --- */
            html, body {
                height: 100%;
                margin: 0;
            }

            body {
                display: flex;
                flex-direction: column;
                background-color: #f4f6f9;
            }

            /* Faz o conteúdo principal crescer e empurrar o footer */
            main {
                flex: 1;
            }

            /* --- ESTILOS VISUAIS --- */
            .navbar {
                background-color: #0f172a !important;
                padding: 0.8rem 1rem;
            }

            .navbar-brand {
                font-weight: bold;
                color: #fff !important;
                font-size: 1.25rem;
            }

            .nav-link {
                color: #cbd5f5 !important;
                font-weight: 500;
            }

                .nav-link:hover {
                    color: #38bdf8 !important;
                }

            .btn-login {
                border: 1px solid #38bdf8;
                color: #38bdf8;
                font-weight: 600;
                border-radius: 8px;
                padding: 5px 15px;
            }

                .btn-login:hover {
                    background-color: #38bdf8;
                    color: #0f172a;
                }

            .btn-register {
                background-color: #38bdf8;
                color: #0f172a;
                font-weight: 600;
                border: none;
                border-radius: 8px;
                padding: 5px 15px;
            }

                .btn-register:hover {
                    background-color: #0ea5e9;
                }

            .footer {
                background-color: #0f172a;
                color: #94a3b8;
                padding: 20px 0;
                border-top: 1px solid rgba(255,255,255,0.1);
            }

                .footer b {
                    color: #38bdf8;
                }
    </style>
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-sm shadow-sm mb-3">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    💰 Sistema Financeiro
                </a>

                <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-flex justify-content-between">

                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Início</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacidade</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-center gap-2">

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link pe-3" asp-area="Identity" asp-page="/Account/Manage/Index">
                                    👤 @User.Identity.Name
                                </a>
                            </li>

                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="m-0">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        Sair
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-login btn-sm"
                                   asp-area="Identity"
                                   asp-page="/Account/Login">
                                    Entrar
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-register btn-sm"
                                   asp-area="Identity"
                                   asp-page="/Account/Register">
                                    Criar conta
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        <div class="container mt-2">
            @RenderBody()
        </div>
    </main>

    <footer class="footer mt-auto">
        <div class="container text-center">
            Sistema Financeiro © 2026 | Desenvolvido por <b>wilson_alves</b>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>