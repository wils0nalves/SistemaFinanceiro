@model SistemaFinanceiro.Models.Requisicao

@{
    ViewData["Title"] = "Detalhes da Requisição";
}

<div class="container mt-4">

    <h2 class="fw-bold mb-3">📄 Detalhes da Requisição</h2>
    <p class="text-muted">Visualize as informações da requisição</p>

    <div class="card shadow-sm p-4">

        <dl class="row">

            <dt class="col-sm-3">Descrição</dt>
            <dd class="col-sm-9">@Model.Descricao</dd>

            <dt class="col-sm-3">Valor</dt>
            <dd class="col-sm-9">R$ @Model.Valor</dd>

            <dt class="col-sm-3">Data</dt>
            <dd class="col-sm-9">@Model.Data.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

        </dl>

        <div class="mt-4">

            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                ✏️ Editar
            </a>

            <a asp-action="Index" class="btn btn-secondary ms-2">
                Voltar
            </a>

        </div>

    </div>

</div>