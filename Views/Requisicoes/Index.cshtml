@model IEnumerable<SistemaFinanceiro.Models.Requisicao>

@{
    ViewData["Title"] = "Requisições";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="fw-bold">📄 Requisições</h2>
            <p class="text-muted mb-0">Lista de requisições cadastradas</p>
        </div>

        <a asp-action="Create" class="btn btn-success">
            + Nova Requisição
        </a>
    </div>

    <div class="card shadow-sm p-3">

        <table class="table table-hover align-middle">

            <thead class="table-light">
                <tr>
                    <th>Descrição</th>
                    <th>Valor</th>
                    <th>Data</th>
                    <th>Status</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Descricao</td>

                        <td>R$ @item.Valor.ToString("N2")</td>

                        <td>@item.Data.ToString("dd/MM/yyyy")</td>

                        <td>
                            @if (item.Status == "Pendente")
                            {
                                <span class="badge bg-warning text-dark">Pendente</span>
                            }
                            else if (item.Status == "Aprovado")
                            {
                                <span class="badge bg-success">Aprovado</span>
                            }
                            else if (item.Status == "Rejeitado")
                            {
                                <span class="badge bg-danger">Rejeitado</span>
                            }
                        </td>

                        <td class="text-end">

                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">
                                Ver
                            </a>

                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                Editar
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                Excluir
                            </a>

                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>