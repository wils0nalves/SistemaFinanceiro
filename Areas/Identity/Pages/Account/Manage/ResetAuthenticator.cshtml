@page
@model ResetAuthenticatorModel
@{
    Layout = null;
    ViewData["Title"] = "Redefinir autenticador";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Financeiro</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            html, body {
                height: 100%;
                margin: 0;
                overflow: hidden;
                font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            }

            .main-container {
                height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab);
                background-size: 400% 400%;
                animation: gradientAnimation 15s ease infinite;
            }

            @@keyframes gradientAnimation {
                0% {
                    background-position: 0% 50%;
                }

                50% {
                    background-position: 100% 50%;
                }

                100% {
                    background-position: 0% 50%;
                }
            }

            .glass-card {
                width: 100%;
                max-width: 420px;
                border-radius: 20px;
                background: rgba(255, 255, 255, 0.9);
                backdrop-filter: blur(12px);
                padding: 30px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            }

            .btn-danger {
                border-radius: 10px;
                padding: 10px;
                font-weight: bold;
            }

            .alert-custom {
                font-size: 0.85rem;
            }
    </style>
</head>
<body>

    <div class="main-container">
        <div class="glass-card">

            <div class="text-center mb-3">
                <h4 class="fw-bold">🔐 Redefinir Autenticador</h4>
                <p class="text-muted small">Gerenciamento de segurança da conta</p>
            </div>

            <div class="alert alert-warning alert-custom" role="alert">
                <strong>Atenção:</strong><br /><br />
                Ao redefinir sua chave do autenticador, seu aplicativo (Google Authenticator, Microsoft Authenticator, etc.)
                deixará de funcionar até que seja configurado novamente.<br /><br />

                Esse processo desativa temporariamente a autenticação em dois fatores (2FA).
                Se você não concluir a reconfiguração, poderá perder acesso à sua conta.
            </div>

            <form method="post">
                <button class="w-100 btn btn-danger text-uppercase">
                    Redefinir autenticador
                </button>
            </form>

            <div class="text-center mt-3">
                <a asp-page="./TwoFactorAuthentication" class="small fw-bold text-decoration-none">
                    ← Voltar
                </a>
            </div>

        </div>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

</body>
</html>