@page
@model ResetPasswordConfirmationModel
@{
    Layout = null;
    ViewData["Title"] = "Senha redefinida";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Financeiro</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            html, body {
                height: 100%;
                margin: 0;
                overflow: hidden;
                font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            }

            .main-container {
                height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                background: linear-gradient(-45deg, #28a745, #20c997, #17a2b8, #6f42c1);
                background-size: 400% 400%;
                animation: gradientAnimation 15s ease infinite;
            }

            @@keyframes gradientAnimation {
                0% {
                    background-position: 0% 50%;
                }

                50% {
                    background-position: 100% 50%;
                }

                100% {
                    background-position: 0% 50%;
                }
            }

            .glass-card {
                width: 100%;
                max-width: 420px;
                border-radius: 20px;
                background: rgba(255, 255, 255, 0.9);
                backdrop-filter: blur(12px);
                padding: 30px;
                text-align: center;
                box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            }

            .btn-primary {
                border-radius: 10px;
                padding: 12px;
                font-weight: bold;
            }
    </style>
</head>
<body>

    <div class="main-container">
        <div class="glass-card">

            <div style="font-size: 3rem;">✅</div>

            <h4 class="fw-bold mt-2">Senha redefinida com sucesso</h4>

            <p class="text-muted small mt-2">
                Sua senha foi atualizada. Agora você já pode acessar o sistema normalmente.
            </p>

            <div class="d-grid mt-4">
                <a asp-page="./Login" class="btn btn-primary text-uppercase">
                    Ir para o login
                </a>
            </div>

        </div>
    </div>

</body>
</html>