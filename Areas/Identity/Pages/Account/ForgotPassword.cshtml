@page
@model ForgotPasswordModel
@{
    Layout = null; // Mantém o padrão de tela cheia sem menus
    ViewData["Title"] = "Recuperar Senha";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Financeiro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            html, body {
                height: 100%;
                margin: 0;
                overflow: hidden;
            }

            @@keyframes gradientAnimation {
                0% {
                    background-position: 0% 50%;
                }

                50% {
                    background-position: 100% 50%;
                }

                100% {
                    background-position: 0% 50%;
                }
            }

            .main-container {
                height: 100vh;
                width: 100vw;
                display: flex;
                justify-content: center;
                align-items: center;
                background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab);
                background-size: 400% 400%;
                animation: gradientAnimation 15s ease infinite;
                padding: 15px;
            }

            .glass-card {
                width: 100%;
                max-width: 420px;
                border-radius: 25px;
                background: rgba(255, 255, 255, 0.85);
                backdrop-filter: blur(15px);
                box-shadow: 0 15px 35px rgba(0,0,0,0.1);
                border: 1px solid rgba(255, 255, 255, 0.3);
                padding: 2rem !important;
            }

            .form-control {
                border-radius: 12px;
                height: 55px;
            }

            .btn-reset {
                border-radius: 12px;
                padding: 12px;
                font-weight: bold;
                background: #0d6efd;
                border: none;
                box-shadow: 0 4px 15px rgba(13, 110, 253, 0.3);
                transition: 0.3s;
            }

                .btn-reset:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 20px rgba(13, 110, 253, 0.4);
                }
    </style>
</head>
<body>

    <div class="main-container">
        <div class="glass-card">
            <div class="text-center mb-4">
                <div style="font-size: 3rem;">🔑</div>
                <h3 class="fw-bold text-dark">Recuperar Senha</h3>
                <p class="text-muted small">Informe seu e-mail para receber as instruções de redefinição.</p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small" role="alert"></div>

                <div class="form-floating mb-4">
                    <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" placeholder="nome@exemplo.com" />
                    <label asp-for="Input.Email">E-mail cadastrado</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <button type="submit" class="w-100 btn btn-primary btn-reset text-uppercase">Enviar Link de Redefinição</button>

                <div class="text-center mt-4">
                    <a asp-page="./Login" class="small fw-bold text-decoration-none">← Voltar para o Login</a>
                </div>
            </form>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>