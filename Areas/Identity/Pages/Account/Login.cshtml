@page
@model LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Entrar";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SAAS - Sistema Financeiro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            html, body {
                height: 100%;
                margin: 0;
                padding: 0;
                overflow: hidden;
                font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            }

            .main-container {
                height: 100vh;
                width: 100vw;
                display: flex;
                justify-content: center;
                align-items: center;
                background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab);
                background-size: 400% 400%;
                animation: gradientAnimation 15s ease infinite;
            }

            @@keyframes gradientAnimation {
                0% {
                    background-position: 0% 50%;
                }

                50% {
                    background-position: 100% 50%;
                }

                100% {
                    background-position: 0% 50%;
                }
            }

            .login-card {
                width: 100%;
                max-width: 360px; /* Reduzido de 400px para 360px */
                border-radius: 20px;
                background: rgba(255, 255, 255, 0.88);
                backdrop-filter: blur(10px);
                padding: 25px 30px; /* Padding mais compacto */
                box-shadow: 0 10px 25px rgba(0,0,0,0.1);
                border: 1px solid rgba(255, 255, 255, 0.3);
            }

            .form-floating > .form-control {
                height: 50px; /* Inputs levemente menores */
                min-height: 50px;
            }

            .form-floating > label {
                padding: 13px 12px;
            }

            .btn-primary {
                border-radius: 10px;
                padding: 10px;
                font-size: 0.9rem;
                letter-spacing: 0.5px;
            }

            .forgot-password, .register-link {
                font-size: 0.8rem;
                color: #0d6efd;
                text-decoration: none;
            }
    </style>
</head>
<body>

    <div class="main-container">
        <div class="login-card">
            <div class="text-center mb-3">
                <h4 class="fw-bold mb-1">💰 SEU SAAS - Sistema Financeiro</h4>
                <p class="text-muted small mb-0">Acesse sua conta</p>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2" role="alert"></div>

                <div class="form-floating mb-2">
                    <input asp-for="Input.Email" class="form-control" placeholder="E-mail" />
                    <label asp-for="Input.Email">E-mail</label>
                </div>

                <div class="form-floating mb-2">
                    <input asp-for="Input.Password" class="form-control" placeholder="Senha" />
                    <label asp-for="Input.Password">Senha</label>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input asp-for="Input.RememberMe" class="form-check-input" />
                        <label class="form-check-label text-muted" style="font-size: 0.75rem;">Lembrar</label>
                    </div>
                    <a asp-page="./ForgotPassword" class="forgot-password fw-bold">Esqueceu a senha?</a>
                </div>

                <button type="submit" class="w-100 btn btn-primary text-uppercase fw-bold">Entrar</button>

                <p class="text-center mt-3 mb-0" style="font-size: 0.8rem;">
                    Não tem conta? <a asp-page="./Register" class="register-link fw-bold">Criar agora</a>
                </p>
            </form>

            <hr class="my-3" style="opacity: 0.08;">

            <div class="text-center">
                <div class="badge bg-primary bg-opacity-10 text-primary mb-1" style="font-family: monospace; font-size: 11px;">
                    &lt;dev_wilson_alves /&gt;
                </div>
                <div class="text-muted" style="font-size: 10px;">yuri.tinocoalves13@hotmail.com</div>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>