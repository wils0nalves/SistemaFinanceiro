@page
@model LoginModel
@{
    Layout = "/Areas/Identity/Pages/Shared/_IdentityLayout.cshtml";
    ViewData["Title"] = "Entrar";
}

<div class="d-flex justify-content-center align-items-center" style="height: 80vh;">

    <div class="card shadow-lg p-4" style="width: 400px; border-radius: 10px;">

        <div class="text-center mb-4">
            <h3 class="fw-bold">💰 Sistema Financeiro</h3>
            <p class="text-muted">Acesse sua conta</p>
        </div>

        <form id="account" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" placeholder="email@exemplo.com" />
                <label asp-for="Input.Email">E-mail</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" placeholder="Senha" />
                <label asp-for="Input.Password">Senha</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label" asp-for="Input.RememberMe">
                    Lembrar de mim
                </label>
            </div>

            <button type="submit" class="w-100 btn btn-primary">
                Entrar
            </button>

            <div class="text-center mt-3">
                <a asp-page="./ForgotPassword" class="d-block mb-1">
                    Esqueceu a senha?
                </a>

                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                    Criar uma conta
                </a>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}