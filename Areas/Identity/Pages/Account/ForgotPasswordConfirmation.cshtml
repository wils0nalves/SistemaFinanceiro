@page
@model ForgotPasswordConfirmation
@{
    Layout = null; // Mantém a estética de tela cheia sem menus
    ViewData["Title"] = "E-mail Enviado";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Financeiro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            /* Reutilizando o fundo animado e o efeito de vidro para consistência visual */
            html, body {
                height: 100%;
                margin: 0;
                overflow: hidden;
            }

            @@keyframes gradientAnimation {
                0% {
                    background-position: 0% 50%;
                }

                50% {
                    background-position: 100% 50%;
                }

                100% {
                    background-position: 0% 50%;
                }
            }

            .main-container {
                height: 100vh;
                width: 100vw;
                display: flex;
                justify-content: center;
                align-items: center;
                background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab);
                background-size: 400% 400%;
                animation: gradientAnimation 15s ease infinite;
                padding: 15px;
            }

            .glass-card {
                width: 100%;
                max-width: 420px;
                border-radius: 25px;
                background: rgba(255, 255, 255, 0.85);
                backdrop-filter: blur(15px);
                box-shadow: 0 15px 35px rgba(0,0,0,0.1);
                border: 1px solid rgba(255, 255, 255, 0.3);
                padding: 3rem !important;
            }
    </style>
</head>
<body>

    <div class="main-container">
        <div class="glass-card text-center">
            <div style="font-size: 4rem; color: #28a745;">📧</div>

            <h3 class="fw-bold text-dark mt-3">Verifique seu e-mail</h3>

            <p class="text-muted">
                Se o endereço informado estiver em nosso sistema, você receberá um link para criar uma nova senha em instantes.
            </p>

            <hr class="my-4" style="opacity: 0.1;">

            <div class="d-grid">
                <a asp-page="./Login" class="btn btn-primary py-2 fw-bold" style="border-radius: 12px; box-shadow: 0 4px 15px rgba(13, 110, 253, 0.3);">
                    Voltar para o Login
                </a>
            </div>
        </div>
    </div>

</body>
</html>